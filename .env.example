# Both Auth MS and Spring Boot must share the same secret.
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Domain & CORS
DOMAIN=yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# Auth DB (RDS)
# RDS endpoint for the auth microservice database
AUTH_DB_HOST=your-auth-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# BeanBalance DB (RDS)
# RDS endpoint for the Spring Boot financial API database
BEAN_DB_HOST=your-bean-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
BEAN_DB_USER=beanbalance
BEAN_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# GitHub Container Registry
# Your GitHub username (lowercase). Used by docker-compose.prod.yml.
GHCR_USER=your-github-username
